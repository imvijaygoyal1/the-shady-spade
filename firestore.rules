rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /game_log/{gameId} {
      allow read, write: if request.auth != null;
    }

    match /player_stats/{playerName} {
      allow read, write: if request.auth != null;
    }

    match /sessions/{sessionId} {
      allow read, write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
