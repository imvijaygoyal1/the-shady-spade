rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /game_log/{gameId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /player_stats/{playerName} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /sessions/{sessionId} {

      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid;

      allow update: if request.auth != null && (
        resource.data.hostUid == request.auth.uid
        || isPlayerInSession(resource.data.playerSlots, request.auth.uid)
        || isJoiningEmptySlot(resource.data.playerSlots, request.resource.data.playerSlots, request.auth.uid)
      );

      allow delete: if request.auth != null
        && resource.data.hostUid == request.auth.uid;
    }

    match /scorekeeperSessions/{sessionId} {

      allow read: if request.auth != null
        && isScorekeeperSession(resource.data);

      allow create: if request.auth != null
        && isValidRoomCode(sessionId)
        && isScorekeeperSession(request.resource.data)
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.isClosed == false
        && request.resource.data.createdAt == request.resource.data.updatedAt
        && request.resource.data.expiresAt > request.time;

      allow update: if request.auth != null
        && isScorekeeperSession(resource.data)
        && isScorekeeperSession(request.resource.data)
        && resource.data.hostUid == request.auth.uid
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.expiresAt == resource.data.expiresAt
        && request.resource.data.updatedAt >= resource.data.updatedAt
        && resource.data.isClosed == false
        && request.time < resource.data.expiresAt;

      allow delete: if false;
    }

    function isValidRoomCode(code) {
      return code.matches('[A-Z0-9]{6}');
    }

    function isScorekeeperSession(data) {
      return data.keys().hasOnly([
          'kind',
          'schemaVersion',
          'createdAt',
          'updatedAt',
          'expiresAt',
          'hostUid',
          'isClosed',
          'playerNames',
          'rounds',
          'runningScores',
          'winnerIndex'
        ])
        && data.kind == 'scorekeeper'
        && data.schemaVersion == 1
        && data.hostUid is string
        && data.hostUid.size() > 0
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && data.expiresAt is timestamp
        && data.isClosed is bool
        && data.playerNames is list
        && data.playerNames.size() == 6
        && data.rounds is list
        && data.rounds.size() <= 100
        && data.runningScores is list
        && data.runningScores.size() == 6
        && data.winnerIndex is int
        && data.winnerIndex >= 0
        && data.winnerIndex < 6;
    }

    function isPlayerInSession(slots, uid) {
      return slots[0].uid == uid
        || slots[1].uid == uid
        || slots[2].uid == uid
        || slots[3].uid == uid
        || slots[4].uid == uid
        || slots[5].uid == uid;
    }

    function isAISlot(slot) {
      return slot.uid.matches('AI-.*');
    }

    function isJoiningEmptySlot(oldSlots, newSlots, uid) {
      return !isPlayerInSession(oldSlots, uid) && (
        (newSlots[0].uid == uid && (!oldSlots[0].joined || isAISlot(oldSlots[0]))) ||
        (newSlots[1].uid == uid && (!oldSlots[1].joined || isAISlot(oldSlots[1]))) ||
        (newSlots[2].uid == uid && (!oldSlots[2].joined || isAISlot(oldSlots[2]))) ||
        (newSlots[3].uid == uid && (!oldSlots[3].joined || isAISlot(oldSlots[3]))) ||
        (newSlots[4].uid == uid && (!oldSlots[4].joined || isAISlot(oldSlots[4]))) ||
        (newSlots[5].uid == uid && (!oldSlots[5].joined || isAISlot(oldSlots[5])))
      );
    }

    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
