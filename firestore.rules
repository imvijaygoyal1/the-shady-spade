rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /game_log/{gameId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /player_stats/{playerName} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /sessions/{sessionId} {

      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid;

      allow update: if request.auth != null && (
        resource.data.hostUid == request.auth.uid
        || isPlayerInSession(resource.data.playerSlots, request.auth.uid)
        || isJoiningEmptySlot(resource.data.playerSlots, request.resource.data.playerSlots, request.auth.uid)
      );

      allow delete: if request.auth != null
        && resource.data.hostUid == request.auth.uid;
    }

    function isPlayerInSession(slots, uid) {
      return slots[0].uid == uid
        || slots[1].uid == uid
        || slots[2].uid == uid
        || slots[3].uid == uid
        || slots[4].uid == uid
        || slots[5].uid == uid;
    }

    function isJoiningEmptySlot(oldSlots, newSlots, uid) {
      return (newSlots[0].uid == uid || newSlots[1].uid == uid ||
              newSlots[2].uid == uid || newSlots[3].uid == uid ||
              newSlots[4].uid == uid || newSlots[5].uid == uid)
        && !isPlayerInSession(oldSlots, uid);
    }

    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
